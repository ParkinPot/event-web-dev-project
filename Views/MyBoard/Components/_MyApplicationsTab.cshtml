<!-- _MyApplicationsTab.cshtml -->
@model event_web_dev_project.Models.MyApplicationsTabModel

<div class="stats-grid stats-grid--4">
    <div class="stat-card">
        <div class="stat-label">Total Applications</div>
        <div class="stat-value stat-value--default">@Model.TotalApplications</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Pending</div>
        <div class="stat-value stat-value--amber">@Model.PendingApplications</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Accepted</div>
        <div class="stat-value stat-value--green">@Model.AcceptedApplications</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Rejected</div>
        <div class="stat-value stat-value--red">@Model.RejectedApplications</div>
    </div>
</div>

<div class="applications-list">
    @foreach (var application in Model.Applications)
    {
    <div class="application-card">
        <div class="application-card__top">
            <div>
                <h3 class="application-card__title">@application.Title</h3>
                <p class="application-card__date">Applied Feb 9, 2026 10:00 AM</p>
            </div>
            <div class="status-badge status-badge--accepted">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Accepted</span>
            </div>
        </div>

        <div class="application-card__message">
            <span class="message-label">Your Message:</span>
            <p>I'm near that area. Happy to grab coffee!</p>
        </div>

        <div class="application-card__notice application-card__notice--success">
            🎉 Congratulations! Your application has been accepted. The organizer will contact you with more details.
        </div>
    </div>
    }
</div>
